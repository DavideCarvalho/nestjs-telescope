{
  "name": "@dudousxd/nestjs-telescope-ai",
  "version": "1.9.0",
  "description": "AI-powered exception diagnosis (Vercel AI SDK) for @dudousxd/nestjs-telescope.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/nestjs-telescope.git",
    "directory": "packages/ai"
  },
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist/", "README.md", "CHANGELOG.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-telescope": "workspace:^",
    "ai": ">=5.0.0"
  },
  "devDependencies": {
    "@ai-sdk/provider": "2.0.3",
    "@dudousxd/nestjs-telescope": "workspace:*",
    "@types/node": "^20.0.0",
    "ai": "5.0.196",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "nestjs",
    "telescope",
    "ai",
    "diagnosis",
    "vercel-ai-sdk",
    "exception",
    "observability"
  ]
}
