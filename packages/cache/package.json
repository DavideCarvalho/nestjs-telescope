{
  "name": "@dudousxd/nestjs-telescope-cache",
  "version": "1.5.0",
  "description": "Cache (get/set hit/miss) watcher for @dudousxd/nestjs-telescope.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCarvalho/nestjs-telescope.git",
    "directory": "packages/cache"
  },
  "author": "Davi Carvalho <davi@goflip.ai>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist/", "README.md", "CHANGELOG.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-telescope": "workspace:^",
    "@nestjs/cache-manager": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/cache-manager": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dudousxd/nestjs-telescope": "workspace:*",
    "@nestjs/cache-manager": "3.1.2",
    "@types/node": "^20.0.0",
    "reflect-metadata": "^0.2.2",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": ["nestjs", "telescope", "cache", "cache-manager", "observability"]
}
